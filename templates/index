<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Surpresa para Isabella ❤️</title>
    <!-- O link agora é direto -->
   <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>
<body>

    <!-- Lateral Esquerda -->
    <div class="side left">
        <div class="scroll">
            <!-- Os caminhos das imagens agora apontam para a pasta 'images' -->
            <img src="{{ url_for('static', filename='images/foto1.jpeg') }}">
            <img src="{{ url_for('static', filename='images/foto2.jpeg') }}">
            <!-- Dupliquei para a animação infinita funcionar -->
            <img src="{{ url_for('static', filename='images/foto1.jpeg') }}">
            <img src="{{ url_for('static', filename='images/foto2.jpeg') }}">
        </div>
    </div>

    <!-- Conteúdo Central -->
    <div class="container-main">
        <div class="wrapper">
            <h1>💌</h1>
            <h2>Minha surpresa para você</h2>
            <p>Escrevi algo especial para você. Digite a senha para ver:</p>

            <form action="/verificar" method="post">
                <input type="text" name="senha" placeholder="Digite a senha..." required>
                <button type="submit">Entrar</button>
            </form>
        </div>
    </div>

    <!-- Lateral Direita -->
    <div class="side right">
        <div class="scroll">
            <img src="{{ url_for('static', filename='images/foto3.jpeg') }}">
            <img src="{{ url_for('static', filename='images/foto4.jpeg') }}">
            <!-- Dupliquei para a animação infinita funcionar -->
            <img src="{{ url_for('static', filename='images/foto3.jpeg') }}">
            <img src="{{ url_for('static', filename='images/foto4.jpeg') }}">
        </div>
    </div>

</body>
</html>
